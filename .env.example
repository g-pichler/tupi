# Copy to .env and fill in the API key(s) for the provider(s) you use.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# Key for the `aqueduct` provider in pi-config/agent/models.json (default
# provider). Only needed if you keep aqueduct as your pi default; leave blank
# otherwise. models.json references it as ${AQUEDUCT_API_KEY}.
# AQUEDUCT_API_KEY=sk-...
